{
  "mcpServers": {
    "wave-os": {
      "command": "node",
      "args": ["./wave-mcp-server/dist/index.js"],
      "env": {
        "BASE44_APP_ID": "YOUR_WAVE_OS_APP_ID",
        "BASE44_API_KEY": "YOUR_WAVE_OS_API_KEY",
        "MCP_ENCRYPTION_KEY": "GENERATE_A_RANDOM_STRING",
        "THETA_API_KEY": "OPTIONAL_YOUR_THETA_API_KEY",
        "THETA_PROJECT_ID": "OPTIONAL_YOUR_THETA_PROJECT_ID",
        "THETA_ALLOW_WRITES": "false"
      }
    }
  }
}
